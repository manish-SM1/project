# CareerAI Advanced Chatbot Configuration
# Copy this file to .env and fill in your API keys

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/careerai?retryWrites=true&w=majority

# LLM Configuration (Required)
LLM_PROVIDER=openrouter
# Options: openai, openrouter, anthropic
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=anthropic/claude-3.5-sonnet
# Options for OpenRouter: anthropic/claude-3.5-sonnet, openai/gpt-4o-mini, google/gemini-pro
# Options for OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# Options for Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229

# OpenAI Configuration (for embeddings - optional)
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration (existing)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# JWT Secret (optional)
JWT_SECRET=your_jwt_secret_key_here

# Server Configuration
PORT=3000
NODE_ENV=development
